{
  "name": "deped-employee-leave-tracker",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npx kill-port 3000 3001",
    "dev": "concurrently \"npm --prefix human-resource-management-system-backend run dev\" \"node --disable-warning=DEP0060 ./node_modules/next/dist/bin/next dev -p 3001\"",
    "dev:backend": "npm --prefix human-resource-management-system-backend run dev",
    "dev:frontend": "node --disable-warning=DEP0060 ./node_modules/next/dist/bin/next dev -p 3001",
    "build": "npm run lint && next build",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "next start -p 3001",
    "start:backend": "npm --prefix human-resource-management-system-backend run start",
    "lint": "next lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.19.0",
    "next": "^15.1.6",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@ljharb/tsconfig": "^0.3.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.6",
    "kill-port": "^2.0.1",
    "typescript": "^5.0.0"
  }
}
